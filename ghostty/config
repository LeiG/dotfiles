font-family = Monaco
font-size = 16

theme = Zenburn

scrollback-limit = 10000

font-thicken = true
adjust-cell-height = 1

window-padding-x = 8
window-padding-y = 8
window-padding-balance = true
window-save-state = always

mouse-hide-while-typing = true

cursor-style = block
cursor-style-blink = true
shell-integration-features = sudo,title
